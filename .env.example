# Environment Variables Template
# Copy this file to .env.local and fill in your values

# API Configuration
VITE_API_BASE_URL=http://localhost:5000/api
VITE_API_VERSION=v1

# CDN & Media
VITE_CDN_URL=https://cdn.streamflix.com
VITE_IMAGE_BASE_URL=https://image.tmdb.org/t/p
VITE_VIDEO_STREAM_URL=https://stream.streamflix.com

# Application
VITE_APP_NAME=StreamFlix
VITE_APP_VERSION=1.0.0
VITE_APP_URL=http://localhost:5173

# Authentication (for future backend integration)
VITE_AUTH_ENABLED=false
VITE_JWT_SECRET=your-secret-key-change-in-production
VITE_TOKEN_EXPIRY=7d

# Feature Flags
VITE_ENABLE_DOWNLOADS=false
VITE_ENABLE_LIVE_TV=true
VITE_ENABLE_SPORTS=true
VITE_ENABLE_ADS=false

# Analytics
VITE_ANALYTICS_ENABLED=false
VITE_GOOGLE_ANALYTICS_ID=

# Error Tracking
VITE_SENTRY_DSN=
VITE_SENTRY_ENVIRONMENT=development

# Service Worker
VITE_ENABLE_PWA=true
VITE_OFFLINE_ENABLED=true

# Video Player
VITE_DEFAULT_QUALITY=auto
VITE_AUTOPLAY_ENABLED=true
VITE_SHOW_SUBTITLES=true

# Content
VITE_CONTENT_PER_PAGE=20
VITE_MAX_SEARCH_RESULTS=50

# Cache
VITE_CACHE_DURATION=3600
VITE_IMAGE_CACHE_DURATION=86400
